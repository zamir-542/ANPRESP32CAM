// secrets.h.example — PlateScope SoftAP credentials + phone IP template.
//
// Copy this file to secrets.h and fill in your values.
// secrets.h is gitignored and must NEVER be committed (invariant #3).
//
// SoftAP mode: the ESP32 CREATES this Wi-Fi network; the phone joins it.
// These are the name/password of the network the device broadcasts — pick
// anything you like (the password must be at least 8 characters for WPA2).

#pragma once

#define AP_SSID      "PlateScope-AP"      // the Wi-Fi name the ESP32 broadcasts
#define AP_PASSWORD  "platescope123"      // min 8 chars; change this

// The phone's IP once it joins the ESP32 AP. The ESP32 is 192.168.4.1 (gateway);
// the phone, as the only client, gets 192.168.4.2. Confirm in Termux with:
//   ip addr | grep 'inet '
#define SERVER_IP    "192.168.4.2"
